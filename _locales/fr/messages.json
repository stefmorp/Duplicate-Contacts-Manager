  "handleDuplicates.windowtitle": {
    "message": "Recherche et traitement des doublons du Carnet d'Adresses"
  },
  "handleDuplicates.introheader": {
    "message": "Comment ça marche ?"
  },
  "handleDuplicates.introtext": {
    "message": "Les entrées correspondantes potentiellement dupliquées vont maintenant être recherchées dans le(s) carnet(s) d'adresses sélectionné(s) ci-dessous."
  },
  "handleDuplicates.chooseSecondary": {
    "message": "Les contacts du premier carnet d’adresse seront comparés (uniquement) à ceux du second. Mettre deux fois le même carnet permet de rechercher les contacts similaires dans celui-ci."
  },
  "handleDuplicates.introtext2": {
    "message": "Chaque fois qu'une paire de candidats est présentée, vous pouvez décider de les ignorer, de les modifier et de les conserver tous les deux, ou de modifier un et d'en supprimer l'autre."
  },
  "handleDuplicates.differentiator": {
    "message": "Si vous souhaitez empêcher les entrées d'être affichées en tant que doublons potentiels à chaque fois, vous pouvez leur donner différents pseudos AIM."
  },
  "handleDuplicates.removeWithoutAsking": {
    "message": "Automatiquement supprimer un des contacts lorsqu’ils sont totalement identiques (ou conserver celui qui a un champs en plus)."
  },
  "handleDuplicates.preserveFirst": {
    "message": "Lorsque vous utilisez deux carnets d'adresses différents, ne supprimez pas automatiquement les entrées du premier."
  },
  "handleDuplicates.deferInteractive": {
    "message": "Collecter tous les duplicats potentiels avant de les présenter."
  },
  "handleDuplicates.durationWarning": {
    "message": "En fonction du nombre d'adresses et du CPU de votre ordinateur, ce processus peut prendre plusieurs minutes."
  },
  "handleDuplicates.natTrunkPrefix": {
    "message": "Préfixe de numéro de téléphone national, par ex. '0'"
  },
  "handleDuplicates.intCallPrefix": {
    "message": "Préfixe de numéro de téléphone international, par ex. '00'"
  },
  "handleDuplicates.countryCallingCode": {
    "message": "Code international par défaut, par ex. '+33'"
  },
  "handleDuplicates.consideredFields": {
    "message": "Champs à considérer"
  },
  "handleDuplicates.ignoredFields": {
    "message": "Champs à ignorer"
  },
  "handleDuplicates.introtext3": {
    "message": "Vous pouvez tout arrêter à n'importe quel moment en pressant sur 'Annuler'. Si vous ne voulez pas traiter un doublon, utilisez le bouton 'Passer'."
  },
  "handleDuplicates.introtext4": {
    "message": "Si vous souhaitez enregistrer les modifications et conserver les deux entrées, cliquez sur 'Conserver les deux'; pour supprimer une entrée, cliquez sur 'Supprimer un'."
  },
  "handleDuplicates.options": {
    "message": "Options"
  },
  "handleDuplicates.endheader": {
    "message": "Résultats"
  },
  "handleDuplicates.endtext": {
