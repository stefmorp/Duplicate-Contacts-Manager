{
  "manifest_version": 3,
  "name": "duplicateContactsManager",
  "description": "Duplicate Contacts Manager for Thunderbird",
  "version": "2.2.2",
  "author": "Marian Steinbach, David von Oheimb, Stefano Morpurgo, et al.",
  "homepage_url": "https://github.com/DDvO/Duplicate-Contacts-Manager",
  "default_locale": "en",
  "browser_specific_settings": {
    "gecko": {
      "id": "duplicateContactsManager@ddvo.net",
      "strict_min_version": "128.0"
    }
  },
  "permissions": [
    "addressBooks",
    "menus",
    "storage"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "action": {
    "default_title": "Duplicate Contacts Manager",
    "default_icon": {
      "64": "chrome/content/kate.png"
    }
  },
  "icons": {
    "64": "chrome/content/kate.png"
  }
}
